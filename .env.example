# ── Betfair credentials ─────────────────────────────────────────────────────
# Sign up at https://www.betfair.com and create a developer application at
# https://developer.betfair.com to get your App Key.
BETFAIR_USERNAME=your_betfair_username
BETFAIR_PASSWORD=your_betfair_password
BETFAIR_APP_KEY=your_betfair_app_key

# ── AI model provider ───────────────────────────────────────────────────────
# Which AI backend to use.
# Options: "anthropic" (default) | "gemini" | "gemini-adk"
#   anthropic  — Claude with extended thinking and server-side web search
#   gemini     — Gemini 2.5 Pro with native function calling
#   gemini-adk — Gemini via Google ADK (Google Search built in alongside Betfair tools)
MODEL_PROVIDER=anthropic

# Anthropic — required when MODEL_PROVIDER=anthropic
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key
# ANTHROPIC_MODEL=claude-opus-4-6   # optional override (default: claude-opus-4-6)

# Google Gemini — required when MODEL_PROVIDER=gemini or gemini-adk
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.5-pro       # optional override

# ── Messaging provider ──────────────────────────────────────────────────────
# Which service receives bet approval requests and agent notifications.
# Options: "whatsapp" (default) | "telegram"
MESSAGING_PROVIDER=whatsapp

# ── WhatsApp via Twilio ─────────────────────────────────────────────────────
# Required when MESSAGING_PROVIDER=whatsapp
# 1. Sign up at https://www.twilio.com and create a project
# 2. Go to Messaging > Try it out > Send a WhatsApp message
# 3. Follow the sandbox setup — send the join code from your WhatsApp number
# 4. Copy Account SID and Auth Token from https://console.twilio.com
# Reply YES or NO to approve/reject bets.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # sandbox number; replace for production
WHATSAPP_TO=whatsapp:+447700900000           # your WhatsApp number

# ── Telegram ────────────────────────────────────────────────────────────────
# Required when MESSAGING_PROVIDER=telegram
# 1. Message @BotFather on Telegram -> /newbot -> save the bot token below
# 2. Send any message to your new bot
# 3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates and find message.chat.id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Betting controls ────────────────────────────────────────────────────────
LIVE_BETTING=false                  # Set true to place real bets (default: false = dry run)
MAX_AUTO_STAKE=10                   # Bets at or below this GBP amount are placed without approval
MAX_STAKE_PER_BET=50                # Hard cap on any single bet (GBP)
APPROVAL_TIMEOUT_SECONDS=300        # Seconds to wait for approval before skipping the bet
HOURS_AHEAD=24                      # How many hours ahead to search for upcoming markets

# ── Two-phase compound strategy ─────────────────────────────────────────────
# Set INITIAL_BANKROLL once when you start. The agent uses this to detect which
# phase it is in. If not set (or 0), it assumes the current balance is the starting point.
INITIAL_BANKROLL=0

# The agent switches from Bootstrap → Compound phase once the bankroll reaches
# this multiple of INITIAL_BANKROLL (default 5 = 5× growth target).
GROWTH_TARGET_MULTIPLIER=5

# Halt betting for the session if the bankroll drops this fraction from its
# session peak — prevents chasing losses (default 0.25 = 25% drawdown limit).
SESSION_DRAWDOWN_LIMIT=0.25

# ── Continuous mode ─────────────────────────────────────────────────────────
# Set CONTINUOUS_MODE=true to keep the agent alive indefinitely:
#   - A2A peer server stays active on A2A_PORT so other agents can connect
#   - WhatsApp/Telegram is polled; any non-approval message triggers a new run
CONTINUOUS_MODE=false
# AUTO_RUN_INTERVAL_MINUTES=360    # Run automatically every N minutes (0 = disabled)

# ── A2A multi-agent topology ────────────────────────────────────────────────
# A2A_ROLE controls how this instance participates in a multi-agent setup.
# Options: "standalone" (default) | "coordinator" | "specialist"
#
#   standalone   — single agent does all research and betting
#   coordinator  — delegates research to specialist agents, then places bets
#   specialist   — handles one sport, returns findings, does NOT place bets
#
# A2A_ROLE=standalone

# Required when A2A_ROLE=specialist — which sport this agent covers.
# Options: football | cricket | rugby
# A2A_SPORT=football

# Port this agent listens on as an A2A server (specialist or peer mode).
# A2A_PORT=3001

# Coordinator mode — URLs of sport-specialist agents to delegate research to.
# A2A_FOOTBALL_URL=http://localhost:3010
# A2A_CRICKET_URL=http://localhost:3011
# A2A_RUGBY_URL=http://localhost:3012

# Standalone peer mode — URL of another GambleBot to pool research with.
# The peer can research markets but cannot place bets.
# A2A_PEER_URL=http://other-agent:3001

# Port this agent exposes as a peer server (alongside its normal run).
# A2A_PEER_PORT=3001
